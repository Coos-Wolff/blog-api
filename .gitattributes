# Force LF for all text files
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.env text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binaries — no line ending conversion
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary